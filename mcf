#!/bin/bash

# mcf - Multi-Cloudflared Manager
# Author: caixax - dios
# Description: Manage multiple Cloudflare tunnels with different accounts on a single VPS.

set -euo pipefail

VERSION="1.2.1"
BASE_DIR="$HOME/.multi-cloudflared"
USERS_DIR="$BASE_DIR/users"
TUNNELS_DIR="$BASE_DIR/tunnels"
LOGS_DIR="$BASE_DIR/logs"
DUMP_FILE="$BASE_DIR/dump.json"
DEFAULT_CLOUDFLARED_DIR="$HOME/.cloudflared"
CF_API_BASE="https://api.cloudflare.com/client/v4"

# ANSI-C quoting → real ESC bytes; safe with both echo and printf, no -e/%b needed.
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
NC=$'\033[0m'

log_info()    { printf '%s[INFO]%s %s\n'    "$BLUE"   "$NC" "$1"; }
log_success() { printf '%s[SUCCESS]%s %s\n' "$GREEN"  "$NC" "$1"; }
log_warning() { printf '%s[WARNING]%s %s\n' "$YELLOW" "$NC" "$1"; }
log_error()   { printf '%s[ERROR]%s %s\n'   "$RED"    "$NC" "$1" >&2; }

check_deps() {
    local missing=()
    command -v cloudflared >/dev/null 2>&1 || missing+=("cloudflared")
    command -v jq          >/dev/null 2>&1 || missing+=("jq")
    command -v curl        >/dev/null 2>&1 || missing+=("curl")
    if [ ${#missing[@]} -gt 0 ]; then
        log_error "Missing dependencies: ${missing[*]}"
        return 1
    fi
}

init_dirs() {
    mkdir -p "$USERS_DIR" "$TUNNELS_DIR" "$LOGS_DIR"
}

show_banner() {
    printf '%s' "$YELLOW"
    cat <<'EOF'
  __  __  _____ ______
 |  \/  |/ ____|  ____|
 | \  / | |    | |__
 | |\/| | |    |  __|
 | |  | | |____| |
 |_|  |_|\_____|_|
EOF
    printf '%s' "$NC"
    echo " Multi-Cloudflared Manager (mcf)"
    echo " By caixax - dios"
    echo " Version: $VERSION"
    echo "---------------------------------"
}

# --- Meta helpers (JSON via jq) ---

# Meta is always JSON. A non-JSON meta is a hard error: we refuse to guess at
# its contents and never rewrite it. Callers must guard meta_* invocations
# (|| true / if) so one corrupted file doesn't abort the whole run under set -e.
meta_assert_json() {
    local meta_file=$1
    if ! jq -e 'type=="object"' "$meta_file" >/dev/null 2>&1; then
        log_error "Tunnel meta is corrupted or not JSON: $meta_file"
        return 1
    fi
}

meta_get() {
    local meta_file=$1
    local key=$2
    [ -f "$meta_file" ] || return 0
    meta_assert_json "$meta_file" || return 1
    jq -r --arg k "$key" '.[$k] // empty' "$meta_file" 2>/dev/null || true
}

meta_get_array() {
    local meta_file=$1
    local key=$2
    [ -f "$meta_file" ] || return 0
    meta_assert_json "$meta_file" || return 1
    jq -r --arg k "$key" '(.[$k] // [])[]' "$meta_file" 2>/dev/null || true
}

meta_set() {
    local meta_file=$1
    local key=$2
    local value=$3
    local tmp
    tmp=$(mktemp)
    if [ -f "$meta_file" ]; then
        meta_assert_json "$meta_file" || { rm -f "$tmp"; return 1; }
        jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$meta_file" > "$tmp"
    else
        jq -n --arg k "$key" --arg v "$value" '{($k): $v}' > "$tmp"
    fi
    mv "$tmp" "$meta_file"
}

meta_add_to_array() {
    local meta_file=$1
    local key=$2
    local value=$3
    local tmp
    tmp=$(mktemp)
    if [ -f "$meta_file" ]; then
        meta_assert_json "$meta_file" || { rm -f "$tmp"; return 1; }
        jq --arg k "$key" --arg v "$value" \
           '.[$k] = ((.[$k] // []) + [$v] | unique)' "$meta_file" > "$tmp"
    else
        jq -n --arg k "$key" --arg v "$value" '{($k): [$v]}' > "$tmp"
    fi
    mv "$tmp" "$meta_file"
}

# --- State helpers (filesystem-driven; no separate DB index) ---

is_running() {
    local tunnel_dir=$1
    local pid_file="$tunnel_dir/pid"
    [ -f "$pid_file" ] || return 1
    local pid
    pid=$(cat "$pid_file" 2>/dev/null || echo "")
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    ps -p "$pid" > /dev/null 2>&1
}

get_next_id() {
    local max_id=0 id meta
    if [ -d "$TUNNELS_DIR" ]; then
        for meta in "$TUNNELS_DIR"/*/meta; do
            [ -f "$meta" ] || continue
            id=$(meta_get "$meta" "id") || true
            if [[ "$id" =~ ^[0-9]+$ ]] && [ "$id" -gt "$max_id" ]; then
                max_id=$id
            fi
        done
    fi
    echo $((max_id + 1))
}

resolve_tunnel_name() {
    local input=$1
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        local meta id
        for meta in "$TUNNELS_DIR"/*/meta; do
            [ -f "$meta" ] || continue
            id=$(meta_get "$meta" "id") || true
            if [ "$id" = "$input" ]; then
                basename "$(dirname "$meta")"
                return 0
            fi
        done
    fi
    if [ -d "$TUNNELS_DIR/$input" ]; then
        echo "$input"
        return 0
    fi
    return 1
}

read_user_api_token() {
    local user=$1
    local token_file="$USERS_DIR/$user/api_token"
    if [ -f "$token_file" ]; then
        tr -d '[:space:]' < "$token_file"
    fi
}

# Names become directory names; block anything that isn't a safe slug before we
# touch the filesystem.
validate_identifier() {
    local kind=$1
    local value=$2
    if [[ ! "$value" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        log_error "$kind must match [a-zA-Z0-9_-]+ (got: '$value')"
        return 1
    fi
}

# --- Cloudflare API helpers (DNS record cleanup on delete) ---

cf_find_zone_id() {
    local api_token=$1
    local hostname=$2
    local user=$3
    local zone_name="$hostname" resp success zone_id code message
    local first=1
    # Walk up the FQDN until Cloudflare recognises a zone the token has access to.
    while true; do
        resp=$(curl -sS --max-time 10 -X GET "${CF_API_BASE}/zones?name=${zone_name}" \
            -H "Authorization: Bearer $api_token" \
            -H "Content-Type: application/json" 2>/dev/null || echo '{}')
        # On the very first request, distinguish "token rejected" (success=false,
        # e.g. code 6003) from "valid token, just no matching zone" (success=true,
        # empty result). Only the latter is worth walking the FQDN up for.
        if [ "$first" -eq 1 ]; then
            success=$(echo "$resp" | jq -r '.success // false' 2>/dev/null || echo "false")
            if [ "$success" != "true" ]; then
                code=$(echo "$resp" | jq -r '.errors[0].code // "unknown"' 2>/dev/null || echo "unknown")
                message=$(echo "$resp" | jq -r '.errors[0].message // "unknown error"' 2>/dev/null || echo "unknown error")
                log_error "Cloudflare API rejected token for user '$user': code $code — $message. Update with: mcf set token $user"
                return 1
            fi
            first=0
        fi
        zone_id=$(echo "$resp" | jq -r '.result[0].id // empty' 2>/dev/null || echo "")
        if [ -n "$zone_id" ]; then
            echo "$zone_id"
            return 0
        fi
        if [[ "$zone_name" == *.* ]]; then
            zone_name="${zone_name#*.}"
        else
            return 1
        fi
    done
}

cf_delete_dns_record() {
    local api_token=$1
    local hostname=$2
    local user=$3

    if [ -z "$api_token" ]; then
        log_warning "No API token for this user; skipping DNS cleanup for $hostname"
        return 0
    fi

    local zone_id
    zone_id=$(cf_find_zone_id "$api_token" "$hostname" "$user" || true)
    if [ -z "$zone_id" ]; then
        log_warning "Cloudflare zone not found for $hostname (token lacks access?)"
        return 1
    fi

    local list_resp record_ids
    list_resp=$(curl -sS --max-time 10 -X GET "${CF_API_BASE}/zones/${zone_id}/dns_records?name=${hostname}" \
        -H "Authorization: Bearer $api_token" \
        -H "Content-Type: application/json" 2>/dev/null || echo '{}')
    record_ids=$(echo "$list_resp" | jq -r '.result[].id' 2>/dev/null || echo "")

    if [ -z "$record_ids" ]; then
        log_warning "No DNS records found for $hostname"
        return 0
    fi

    local rid del_resp ok err
    while IFS= read -r rid; do
        [ -z "$rid" ] && continue
        del_resp=$(curl -sS --max-time 10 -X DELETE "${CF_API_BASE}/zones/${zone_id}/dns_records/${rid}" \
            -H "Authorization: Bearer $api_token" \
            -H "Content-Type: application/json" 2>/dev/null || echo '{}')
        ok=$(echo "$del_resp" | jq -r '.success // false' 2>/dev/null || echo "false")
        if [ "$ok" = "true" ]; then
            log_success "Deleted DNS record $hostname"
        else
            err=$(echo "$del_resp" | jq -r '.errors[0].message // "unknown error"' 2>/dev/null || echo "parse error")
            log_warning "Failed to delete DNS record $hostname: $err"
        fi
    done <<< "$record_ids"
}

# --- Commands ---

cmd_create_user() {
    local username=${1:-}
    if [ -z "$username" ]; then
        log_error "Usage: mcf create user <username>"
        return 1
    fi
    validate_identifier "Username" "$username" || return 1

    local user_dir="$USERS_DIR/$username"
    if [ -d "$user_dir" ]; then
        log_error "User '$username' already exists."
        return 1
    fi

    log_info "Creating user '$username'..."

    # cloudflared tunnel login writes to ~/.cloudflared/cert.pem (fixed path).
    # Backup + restore the global cert so concurrent users don't clobber each other.
    local global_cert="$DEFAULT_CLOUDFLARED_DIR/cert.pem"
    if [ -f "$global_cert" ]; then
        log_warning "Backing up existing global cert.pem..."
        mv "$global_cert" "$global_cert.bak"
    fi

    log_info "Please log in to Cloudflare in the browser window that appears."
    cloudflared tunnel login || true

    if [ -f "$global_cert" ]; then
        mkdir -p "$user_dir"
        mv "$global_cert" "$user_dir/cert.pem"
        chmod 600 "$user_dir/cert.pem"
        log_success "User '$username' created."
    else
        log_error "Login failed or cert.pem not found."
        if [ -f "$global_cert.bak" ]; then
            mv "$global_cert.bak" "$global_cert"
        fi
        return 1
    fi

    if [ -f "$global_cert.bak" ]; then
        mv "$global_cert.bak" "$global_cert"
    fi

    # Optional API token for DNS record cleanup on `mcf delete`. Interactive only.
    if [ -t 0 ]; then
        printf 'Cloudflare API token for %s (optional, Enter to skip): ' "$username"
        local api_token=""
        read -r api_token || true
        if [ -n "$api_token" ]; then
            printf '%s\n' "$api_token" > "$user_dir/api_token"
            chmod 600 "$user_dir/api_token"
            log_success "API token saved."
        else
            log_warning "No API token saved. 'mcf delete' will NOT remove DNS records for this user."
            log_warning "Set later via: mcf set token $username"
        fi
    else
        log_warning "Non-interactive shell; skipping API token prompt."
        log_warning "Set it later via: mcf set token $username"
    fi
}

cmd_set_token() {
    local sub=${1:-}
    if [ "$sub" != "token" ]; then
        log_error "Usage: mcf set token <user>"
        return 1
    fi
    local username=${2:-}
    if [ -z "$username" ]; then
        log_error "Usage: mcf set token <user>"
        return 1
    fi
    local user_dir="$USERS_DIR/$username"
    if [ ! -d "$user_dir" ]; then
        log_error "User '$username' not found."
        return 1
    fi
    if [ ! -t 0 ]; then
        log_error "set token requires an interactive TTY (avoids leaving the token in shell history)."
        return 1
    fi
    printf 'Cloudflare API token for %s: ' "$username"
    local api_token=""
    read -r api_token || true
    if [ -z "$api_token" ]; then
        log_error "Empty token; aborting."
        return 1
    fi
    printf '%s\n' "$api_token" > "$user_dir/api_token"
    chmod 600 "$user_dir/api_token"
    log_success "API token updated for $username."
}

cmd_list_users() {
    log_info "Registered Users:"
    if [ -d "$USERS_DIR" ] && [ -n "$(ls -A "$USERS_DIR" 2>/dev/null || true)" ]; then
        local user_path user marker
        for user_path in "$USERS_DIR"/*/; do
            [ -d "$user_path" ] || continue
            user=$(basename "$user_path")
            marker=""
            [ -f "$USERS_DIR/$user/api_token" ] && marker=" [token set]"
            echo " - $user$marker"
            if [ -f "$USERS_DIR/$user/domains" ]; then
                echo "   Domains:"
                local domain
                while IFS= read -r domain; do
                    [ -n "$domain" ] && echo "     * $domain"
                done < "$USERS_DIR/$user/domains"
            fi
        done
    else
        echo " No users found."
    fi
}

cmd_add_domain() {
    local domain=${1:-}; shift || true
    local username=""
    while [ $# -gt 0 ]; do
        case ${1:-} in
            --user) username="${2:-}"; shift 2 ;;
            *)      shift ;;
        esac
    done
    if [ -z "$domain" ] || [ -z "$username" ]; then
        log_error "Usage: mcf add domain <domain> --user <username>"
        return 1
    fi
    local user_dir="$USERS_DIR/$username"
    if [ ! -d "$user_dir" ]; then
        log_error "User '$username' not found."
        return 1
    fi
    if [ -f "$user_dir/domains" ] && grep -Fxq "$domain" "$user_dir/domains"; then
        log_warning "Domain '$domain' already tracked for $username."
        return 0
    fi
    printf '%s\n' "$domain" >> "$user_dir/domains"
    log_success "Domain '$domain' added for user '$username'."
}

cmd_create_tunnel() {
    local tunnel_name=${1:-}; shift || true
    local username=""
    while [ $# -gt 0 ]; do
        case ${1:-} in
            --user) username="${2:-}"; shift 2 ;;
            *)      shift ;;
        esac
    done

    if [ -z "$tunnel_name" ] || [ -z "$username" ]; then
        log_error "Usage: mcf create tunnel <name> --user <user>"
        return 1
    fi
    validate_identifier "Tunnel name" "$tunnel_name" || return 1

    local user_cert="$USERS_DIR/$username/cert.pem"
    if [ ! -f "$user_cert" ]; then
        log_error "User cert not found: $user_cert"
        return 1
    fi

    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    if [ -d "$tunnel_dir" ]; then
        log_error "Tunnel '$tunnel_name' already exists."
        return 1
    fi

    log_info "Creating tunnel '$tunnel_name'..."

    mkdir -p "$tunnel_dir"
    local creds_path="$tunnel_dir/creds.json"
    rm -f "$creds_path"

    # --origincert is a tunnel-subcommand-level flag (BEFORE `create`).
    # --output json + --credentials-file are options of `create` (AFTER).
    local output create_rc=0
    output=$(cloudflared tunnel --origincert "$user_cert" create \
        --output json \
        --credentials-file "$creds_path" \
        "$tunnel_name" 2>&1) || create_rc=$?

    local uuid
    uuid=$(echo "$output" | jq -r '.id' 2>/dev/null || echo "")
    if [ -z "$uuid" ] || [ "$uuid" = "null" ]; then
        uuid=$(echo "$output" \
            | grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}' \
            | head -n1 \
            | tr -d '[:space:]' || true)
    fi

    if [ "$create_rc" -ne 0 ] || [ -z "$uuid" ]; then
        log_error "Failed to create tunnel or extract UUID."
        echo "$output" >&2
        rm -f "$creds_path"
        rmdir "$tunnel_dir" 2>/dev/null || true
        return 1
    fi

    if [ ! -f "$creds_path" ]; then
        log_error "Tunnel created in Cloudflare but credentials file missing at $creds_path"
        echo "$output" >&2
        return 1
    fi

    local id
    id=$(get_next_id)
    local meta="$tunnel_dir/meta"
    jq -n \
        --arg uuid "$uuid" \
        --arg user "$username" \
        --arg name "$tunnel_name" \
        --arg id "$id" \
        --arg creds "$creds_path" \
        --arg created_at "$(date -Iseconds)" \
        '{uuid:$uuid, user:$user, name:$name, id:$id, creds:$creds, created_at:$created_at, hostnames:[]}' \
        > "$meta"

    log_success "Tunnel '$tunnel_name' created (ID: $id, UUID: $uuid)"
}

cmd_route_tunnel() {
    local input=${1:-}
    local hostname=${2:-}
    if [ -z "$input" ] || [ -z "$hostname" ]; then
        log_error "Usage: mcf route <id|name> <hostname>"
        return 1
    fi

    local tunnel_name
    tunnel_name=$(resolve_tunnel_name "$input" || true)
    if [ -z "$tunnel_name" ]; then
        log_error "Tunnel '$input' does not exist."
        return 1
    fi

    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    local meta="$tunnel_dir/meta"
    if [ ! -f "$meta" ]; then
        log_error "Tunnel meta missing: $meta"
        return 1
    fi

    local user uuid
    user=$(meta_get "$meta" "user") || true
    uuid=$(meta_get "$meta" "uuid") || true
    if [ -z "$user" ] || [ -z "$uuid" ]; then
        log_error "Tunnel meta is incomplete (missing user/uuid)."
        return 1
    fi
    local user_cert="$USERS_DIR/$user/cert.pem"
    if [ ! -f "$user_cert" ]; then
        log_error "User cert missing for owner '$user': $user_cert"
        return 1
    fi

    # --origincert avoids the racy global cert swap that 1.1.x used.
    local ret=0
    cloudflared tunnel --origincert "$user_cert" route dns "$uuid" "$hostname" || ret=$?
    if [ $ret -ne 0 ]; then
        log_error "Failed to route DNS for $hostname"
        return $ret
    fi

    meta_add_to_array "$meta" "hostnames" "$hostname" \
        || log_warning "Routed $hostname but failed to record it in meta."
    log_success "Routed $hostname -> $tunnel_name"
}

cmd_start_tunnel() {
    local input=${1:-}
    local target=${2:-}

    if [ -z "$input" ]; then
        log_error "Usage: mcf start <id|name> [url|port]"
        return 1
    fi

    local tunnel_name
    tunnel_name=$(resolve_tunnel_name "$input" || true)
    if [ -z "$tunnel_name" ]; then
        log_error "Tunnel '$input' does not exist."
        return 1
    fi

    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    local meta="$tunnel_dir/meta"
    local creds="$tunnel_dir/creds.json"

    [ -f "$meta" ]  || { log_error "Meta file not found: $meta";          return 1; }
    [ -f "$creds" ] || { log_error "Credentials file not found: $creds";  return 1; }

    local user uuid id
    user=$(meta_get "$meta" "user") || true
    uuid=$(meta_get "$meta" "uuid") || true
    id=$(meta_get "$meta" "id") || true
    if [ -z "$user" ] || [ -z "$uuid" ]; then
        log_error "Tunnel meta is incomplete (missing user/uuid)."
        return 1
    fi
    local user_cert="$USERS_DIR/$user/cert.pem"
    [ -f "$user_cert" ] || { log_error "User cert missing for owner '$user': $user_cert"; return 1; }

    local url=""
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        url="http://localhost:$target"
    elif [[ "$target" == http* ]]; then
        url="$target"
    elif [ -z "$target" ]; then
        url=$(meta_get "$meta" "url") || true
    fi
    if [ -z "$url" ]; then
        log_error "No URL/port provided and no previous URL stored in meta."
        return 1
    fi

    if is_running "$tunnel_dir"; then
        local existing_pid
        existing_pid=$(cat "$tunnel_dir/pid")
        log_error "Tunnel '$tunnel_name' already running (PID: $existing_pid)."
        return 1
    fi
    rm -f "$tunnel_dir/pid"

    # Always override any inherited TUNNEL_ORIGIN_CERT so child cloudflared uses THIS user's cert,
    # never whatever the parent shell happened to export.
    export TUNNEL_ORIGIN_CERT="$user_cert"

    local log_file="$LOGS_DIR/$tunnel_name.log"
    nohup cloudflared tunnel run --url "$url" --credentials-file "$creds" "$uuid" \
        > "$log_file" 2>&1 &
    local pid=$!
    echo "$pid" > "$tunnel_dir/pid"

    # Confirm the process didn't die immediately (bad cert, port in use, bad UUID, ...).
    sleep 1
    if ! ps -p "$pid" > /dev/null 2>&1; then
        rm -f "$tunnel_dir/pid"
        log_error "Tunnel '$tunnel_name' failed to start. Last log lines:"
        tail -n 15 "$log_file" 2>/dev/null || true
        return 1
    fi

    meta_set "$meta" "url" "$url" \
        || log_warning "Tunnel started but failed to persist URL to meta for $tunnel_name."
    log_success "Started tunnel '$tunnel_name' (ID: ${id:-?}, PID: $pid) -> $url"
}

cmd_stop_tunnel() {
    local input=${1:-}
    if [ -z "$input" ]; then
        log_error "Usage: mcf stop <id|name>"
        return 1
    fi
    local tunnel_name
    tunnel_name=$(resolve_tunnel_name "$input" || true)
    if [ -z "$tunnel_name" ]; then
        log_error "Tunnel '$input' does not exist."
        return 1
    fi
    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    if [ -f "$tunnel_dir/pid" ]; then
        local pid
        pid=$(cat "$tunnel_dir/pid" 2>/dev/null || echo "")
        if [[ "$pid" =~ ^[0-9]+$ ]]; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$tunnel_dir/pid"
        log_success "Stopped $tunnel_name"
    else
        log_warning "Not running"
    fi
}

cmd_restart_tunnel() {
    local input=${1:-}
    cmd_stop_tunnel "$input" || true
    sleep 1
    cmd_start_tunnel "$input"
}

cmd_delete_tunnel() {
    local input=${1:-}
    if [ -z "$input" ]; then
        log_error "Usage: mcf delete <id|name>"
        return 1
    fi
    local tunnel_name
    tunnel_name=$(resolve_tunnel_name "$input" || true)
    if [ -z "$tunnel_name" ]; then
        log_error "Tunnel '$input' does not exist."
        return 1
    fi
    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    local meta="$tunnel_dir/meta"

    cmd_stop_tunnel "$tunnel_name" > /dev/null 2>&1 || true

    local user="" uuid=""
    if [ -f "$meta" ]; then
        user=$(meta_get "$meta" "user") || true
        uuid=$(meta_get "$meta" "uuid") || true
    fi

    if [ -n "$uuid" ] && [ -n "$user" ]; then
        local user_cert="$USERS_DIR/$user/cert.pem"
        if [ -f "$user_cert" ]; then
            log_info "Cleaning up tunnel connections (cloudflared cleanup)..."
            cloudflared tunnel --origincert "$user_cert" cleanup "$uuid" \
                || log_warning "cloudflared cleanup failed (continuing)."
            log_info "Deleting tunnel from Cloudflare..."
            if cloudflared tunnel --origincert "$user_cert" delete -f "$uuid"; then
                log_success "Tunnel deleted from Cloudflare."
            else
                log_warning "cloudflared delete failed (continuing with local cleanup)."
            fi
        else
            log_warning "User cert missing for '$user'; skipping remote tunnel deletion."
        fi

        local api_token hostnames
        api_token=$(read_user_api_token "$user") || true
        hostnames=$(meta_get_array "$meta" "hostnames") || true
        if [ -n "$hostnames" ]; then
            local hn
            while IFS= read -r hn; do
                [ -z "$hn" ] && continue
                cf_delete_dns_record "$api_token" "$hn" "$user" || true
            done <<< "$hostnames"
        fi
    else
        log_warning "Meta missing or incomplete; skipping remote cleanup."
    fi

    rm -rf "$tunnel_dir"
    rm -f "$LOGS_DIR/$tunnel_name.log"
    log_success "Deleted tunnel $tunnel_name"
}

cmd_logs() {
    local input=${1:-}
    shift || true
    local lines=20
    while [ $# -gt 0 ]; do
        case ${1:-} in
            --lines) lines="${2:-20}"; shift 2 ;;
            *)       shift ;;
        esac
    done
    if [ -z "$input" ]; then
        log_error "Usage: mcf logs <id|name> [--lines N]"
        return 1
    fi
    local tunnel_name
    tunnel_name=$(resolve_tunnel_name "$input" || true)
    if [ -z "$tunnel_name" ]; then
        log_error "Tunnel '$input' does not exist."
        return 1
    fi
    local log_file="$LOGS_DIR/$tunnel_name.log"
    if [ -f "$log_file" ]; then
        tail -n "$lines" -f "$log_file"
    else
        log_error "No logs for $tunnel_name"
        return 1
    fi
}

cmd_list_tunnels() {
    printf '%s%-4s %-15s %-15s %-9s %-8s %-25s %-20s%s\n' \
        "$CYAN" "ID" "NAME" "USER" "STATUS" "PID" "HOSTNAMES" "LOCAL" "$NC"
    echo "-------------------------------------------------------------------------------------------------------"

    if [ ! -d "$TUNNELS_DIR" ]; then
        echo "No tunnels found."
        return 0
    fi

    # Sort tunnels by numeric id; ids missing/garbage sort first so they're visible.
    local sorted
    sorted=$(for meta in "$TUNNELS_DIR"/*/meta; do
        [ -f "$meta" ] || continue
        printf '%s\t%s\n' "$(meta_get "$meta" "id")" "$meta"
    done | sort -n -k1,1 || true)

    if [ -z "$sorted" ]; then
        echo "No tunnels found."
        return 0
    fi

    local id meta name user url hostnames pid status_kind status_text status_color tunnel_dir p
    while IFS=$'\t' read -r id meta; do
        [ -f "$meta" ] || continue
        name=$(basename "$(dirname "$meta")")
        user=$(meta_get "$meta" "user") || true
        url=$(meta_get "$meta" "url") || true
        hostnames=$(meta_get_array "$meta" "hostnames" | paste -sd, - 2>/dev/null || true)
        [ -z "$user" ]      && user="?"
        [ -z "$url" ]       && url="-"
        [ -z "$hostnames" ] && hostnames="-"
        [ -z "$id" ]        && id="?"

        tunnel_dir="$TUNNELS_DIR/$name"
        pid="-"
        status_kind="stopped"
        if [ -f "$tunnel_dir/pid" ]; then
            p=$(cat "$tunnel_dir/pid" 2>/dev/null || echo "")
            if [[ "$p" =~ ^[0-9]+$ ]] && ps -p "$p" > /dev/null 2>&1; then
                status_kind="online"
                pid="$p"
            else
                status_kind="err"
            fi
        fi
        case "$status_kind" in
            online)  status_text="ONLINE";  status_color="$GREEN" ;;
            err)     status_text="ERR";     status_color="$RED"   ;;
            stopped) status_text="STOPPED"; status_color="$RED"   ;;
        esac

        printf '%-4s %-15s %-15s ' "$id" "$name" "$user"
        printf '%s%-9s%s'          "$status_color" "$status_text" "$NC"
        printf ' %-8s %-25s %-20s\n' "$pid" "$hostnames" "$url"
    done <<< "$sorted"
}

cmd_purge_user() {
    local sub=${1:-}
    if [ "$sub" != "user" ]; then
        log_error "Usage: mcf purge user <name>"
        return 1
    fi
    local username=${2:-}
    if [ -z "$username" ]; then
        log_error "Usage: mcf purge user <name>"
        return 1
    fi
    local user_dir="$USERS_DIR/$username"
    if [ ! -d "$user_dir" ]; then
        log_error "User '$username' not found."
        return 1
    fi

    log_warning "This will delete ALL tunnels owned by '$username', their DNS records, and the user itself."
    if [ -t 0 ]; then
        printf 'Type the username to confirm: '
        local confirm=""
        read -r confirm || true
        if [ "$confirm" != "$username" ]; then
            log_error "Confirmation mismatch; aborted."
            return 1
        fi
    else
        log_error "purge user requires interactive confirmation."
        return 1
    fi

    local meta name owner
    for meta in "$TUNNELS_DIR"/*/meta; do
        [ -f "$meta" ] || continue
        owner=$(meta_get "$meta" "user") || true
        if [ "$owner" = "$username" ]; then
            name=$(basename "$(dirname "$meta")")
            log_info "Purging tunnel: $name"
            cmd_delete_tunnel "$name" || log_warning "Failed to fully delete $name (continuing)"
        fi
    done

    rm -rf "$user_dir"
    log_success "User '$username' purged."
}

# Note: only tunnel names are saved. The URL each tunnel runs against is
# persisted to its meta on every successful `start`, and `resurrect` reads it
# back from there. Snapshot stays minimal on purpose.
cmd_save() {
    log_info "Saving running tunnels..."
    : > "$DUMP_FILE"
    if [ -d "$TUNNELS_DIR" ]; then
        local tunnel_dir name
        for tunnel_dir in "$TUNNELS_DIR"/*/; do
            [ -d "$tunnel_dir" ] || continue
            if is_running "$tunnel_dir"; then
                name=$(basename "$tunnel_dir")
                printf '%s\n' "$name" >> "$DUMP_FILE"
            fi
        done
    fi
    log_success "Saved running tunnels to $DUMP_FILE"
}

cmd_resurrect() {
    log_info "Resurrecting tunnels..."
    if [ -f "$DUMP_FILE" ]; then
        local name
        while IFS= read -r name; do
            [ -n "$name" ] || continue
            log_info "Starting $name..."
            cmd_start_tunnel "$name" || log_warning "Failed to start $name"
        done < "$DUMP_FILE"
    else
        log_error "No save dump found."
        return 1
    fi
}

cmd_startup() {
    local service_file="/etc/systemd/system/mcf.service"
    local mcf_path
    mcf_path=$(realpath "$0")

    # Under `sudo mcf startup`, $USER/$HOME are root's, but the data lives in the
    # invoking user's home. Resolve the real user so the unit points at it.
    local effective_user="${SUDO_USER:-$USER}"
    local effective_home
    effective_home=$(getent passwd "$effective_user" | cut -d: -f6 || true)
    if [ -z "$effective_home" ]; then
        log_error "Cannot resolve home directory for $effective_user"
        return 1
    fi

    log_info "Generating systemd service for user '$effective_user'..."
    local svc_content
    svc_content=$(cat <<EOF
[Unit]
Description=Multi-Cloudflared Manager
After=network.target

[Service]
Type=forking
User=$effective_user
ExecStart=$mcf_path resurrect
Environment=HOME=$effective_home

[Install]
WantedBy=multi-user.target
EOF
)

    if [ "$EUID" -ne 0 ]; then
        log_warning "Root privileges needed; using sudo..."
        echo "$svc_content" | sudo tee "$service_file" > /dev/null
        sudo systemctl daemon-reload
        sudo systemctl enable mcf
    else
        echo "$svc_content" > "$service_file"
        systemctl daemon-reload
        systemctl enable mcf
    fi
    log_success "Startup service enabled."
    echo "You can now use 'mcf save' to freeze the process list."
}

show_help() {
    show_banner
    cat <<'EOF'
Commands:
  create user <name>              Create a Cloudflare account user (login + optional API token)
  create tunnel <name> --user U   Create a tunnel for user U
  list                            Show all tunnels (status table)
  list users                      Show registered users
  start <id|name> [port|url]      Start tunnel (port shorthand or full URL)
  stop <id|name>                  Stop tunnel
  restart <id|name>               Restart tunnel
  delete <id|name>                Delete tunnel locally AND in Cloudflare (+ DNS records if token set)
  logs <id|name> [--lines N]      Tail tunnel logs (default 20 lines)
  route <id|name> <hostname>      Route DNS hostname to tunnel (CNAME)
  add domain <domain> --user U    Track a domain under a user (informational)
  set token <user>                Set / update Cloudflare API token for user
  purge user <name>               Delete every tunnel of a user, their DNS records, and the user
  save                            Snapshot currently-running tunnels for boot resurrection
  resurrect                       Start tunnels from the last save snapshot
  startup                         Install systemd unit that runs `resurrect` on boot
  help                            Show this help
EOF
}

# --- Main Dispatcher ---

init_dirs

sub=""
case "${1:-help}" in
    setup)
        check_deps
        log_success "Ready."
        ;;
    create)
        shift
        sub=${1:-}
        if [ "$sub" = "user" ]; then
            shift; cmd_create_user "$@"
        elif [ "$sub" = "tunnel" ]; then
            shift; cmd_create_tunnel "$@"
        else
            log_error "Usage: mcf create {user|tunnel} ..."
            exit 1
        fi
        ;;
    add)
        shift
        sub=${1:-}
        if [ "$sub" = "domain" ]; then
            shift; cmd_add_domain "$@"
        else
            log_error "Usage: mcf add domain <domain> --user <user>"
            exit 1
        fi
        ;;
    set)
        shift; cmd_set_token "$@"
        ;;
    purge)
        shift; cmd_purge_user "$@"
        ;;
    route)
        shift; cmd_route_tunnel "$@"
        ;;
    list)
        shift
        sub=${1:-}
        if [ "$sub" = "users" ]; then
            cmd_list_users
        else
            cmd_list_tunnels
        fi
        ;;
    start)     shift; cmd_start_tunnel "$@" ;;
    stop)      shift; cmd_stop_tunnel "$@" ;;
    restart)   shift; cmd_restart_tunnel "$@" ;;
    delete)    shift; cmd_delete_tunnel "$@" ;;
    logs)      shift; cmd_logs "$@" ;;
    save)      cmd_save ;;
    resurrect) cmd_resurrect ;;
    startup)   cmd_startup ;;
    help|--help|-h|*)
        show_help
        ;;
esac
