#!/bin/bash

# mcf - Multi-Cloudflared Manager
# Author: caixax - dios
# Description: Manage multiple Cloudflare tunnels with different accounts on a single VPS.

VERSION="1.1.2"
BASE_DIR="$HOME/.multi-cloudflared"
USERS_DIR="$BASE_DIR/users"
TUNNELS_DIR="$BASE_DIR/tunnels"
LOGS_DIR="$BASE_DIR/logs"
DB_FILE="$BASE_DIR/index.db"
DUMP_FILE="$BASE_DIR/dump.json"
DEFAULT_CLOUDFLARED_DIR="$HOME/.cloudflared"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Helper Functions
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

check_deps() {
    if ! command -v cloudflared &> /dev/null; then
        log_error "cloudflared is not installed. Please install it first."
        exit 1
    fi
    if ! command -v jq &> /dev/null; then
        log_warning "jq is not installed. Installing..."
        if [ -f /etc/debian_version ]; then
            sudo apt-get update && sudo apt-get install -y jq
        else
            log_error "Please install 'jq' manually."
            exit 1
        fi
    fi
}

init_dirs() {
    mkdir -p "$USERS_DIR"
    mkdir -p "$TUNNELS_DIR"
    mkdir -p "$LOGS_DIR"
    if [ ! -f "$DB_FILE" ]; then
        touch "$DB_FILE"
    fi
}

# Banner
show_banner() {
    echo -e "${YELLOW}"
    echo "  __  __  _____ ______ "
    echo " |  \/  |/ ____|  ____|"
    echo " | \  / | |    | |__   "
    echo " | |\/| | |    |  __|  "
    echo " | |  | | |____| |     "
    echo " |_|  |_|\_____|_|     "
    echo -e "${NC}"
    echo " Multi-Cloudflared Manager (mcf)"
    echo " By caixax - dios"
    echo " Version: $VERSION"
    echo "---------------------------------"
}

# DB Helpers
get_next_id() {
    local max_id=0
    if [ -f "$DB_FILE" ]; then
        while IFS='|' read -r id name user; do
            if [[ "$id" =~ ^[0-9]+$ ]] && [ "$id" -gt "$max_id" ]; then
                max_id=$id
            fi
        done < "$DB_FILE"
    fi
    echo $((max_id + 1))
}

add_to_db() {
    local id=$1
    local name=$2
    local user=$3
    echo "$id|$name|$user" >> "$DB_FILE"
}

remove_from_db() {
    local id=$1
    local temp_file="$DB_FILE.tmp"
    grep -v "^$id|" "$DB_FILE" > "$temp_file"
    mv "$temp_file" "$DB_FILE"
}

get_tunnel_by_id_or_name() {
    local input=$1
    local tunnel_name=""
    
    # Check if input is ID
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        tunnel_name=$(grep "^$input|" "$DB_FILE" | cut -d'|' -f2)
    else
        # Input is Name
        tunnel_name=$input
    fi
    echo "$tunnel_name"
}

get_id_by_name() {
    local name=$1
    grep "|${name}|" "$DB_FILE" | cut -d'|' -f1
}

# Commands

cmd_create_user() {
    local username=$1
    if [ -z "$username" ]; then
        log_error "Usage: mcf create user <username>"
        return 1
    fi

    local user_dir="$USERS_DIR/$username"
    if [ -d "$user_dir" ]; then
        log_error "User '$username' already exists."
        return 1
    fi

    log_info "Creating user '$username'..."
    
    if [ -f "$DEFAULT_CLOUDFLARED_DIR/cert.pem" ]; then
        log_warning "Backing up existing global cert.pem..."
        mv "$DEFAULT_CLOUDFLARED_DIR/cert.pem" "$DEFAULT_CLOUDFLARED_DIR/cert.pem.bak"
    fi

    log_info "Please log in to Cloudflare in the browser window that appears."
    cloudflared tunnel login

    if [ -f "$DEFAULT_CLOUDFLARED_DIR/cert.pem" ]; then
        mkdir -p "$user_dir"
        mv "$DEFAULT_CLOUDFLARED_DIR/cert.pem" "$user_dir/cert.pem"
        log_success "User '$username' created successfully!"
    else
        log_error "Login failed or cert.pem not found."
    fi

    if [ -f "$DEFAULT_CLOUDFLARED_DIR/cert.pem.bak" ]; then
        mv "$DEFAULT_CLOUDFLARED_DIR/cert.pem.bak" "$DEFAULT_CLOUDFLARED_DIR/cert.pem"
    fi
}

cmd_list_users() {
    log_info "Registered Users:"
    if [ -d "$USERS_DIR" ]; then
        ls -1 "$USERS_DIR" | while read -r user; do
            echo " - $user"
            if [ -f "$USERS_DIR/$user/domains" ]; then
                echo "   Domains:"
                while read -r domain; do
                    echo "     * $domain"
                done < "$USERS_DIR/$user/domains"
            fi
        done
    else
        echo " No users found."
    fi
}

cmd_add_domain() {
    shift; local domain=$1; shift;
    local username=""
    while [[ "$#" -gt 0 ]]; do
        case $1 in --user) username="$2"; shift ;; *) shift ;; esac
    done
    if [ -z "$domain" ] || [ -z "$username" ]; then
        log_error "Usage: mcf add domain <domain> --user <username>"
        return 1
    fi
    local user_dir="$USERS_DIR/$username"
    [ ! -d "$user_dir" ] && { log_error "User not found"; return 1; }
    echo "$domain" >> "$user_dir/domains"
    log_success "Domain added."
}

cmd_create_tunnel() {
    local tunnel_name=$1; shift;
    local username=""
    while [[ "$#" -gt 0 ]]; do
        case $1 in --user) username="$2"; shift ;; *) shift ;; esac
    done

    if [ -z "$tunnel_name" ] || [ -z "$username" ]; then
        log_error "Usage: mcf create tunnel <name> --user <user>"
        return 1
    fi

    local user_cert="$USERS_DIR/$username/cert.pem"
    [ ! -f "$user_cert" ] && { log_error "User cert not found"; return 1; }
    
    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    [ -d "$tunnel_dir" ] && { log_error "Tunnel exists"; return 1; }

    log_info "Creating tunnel '$tunnel_name'..."
    local output
    # cloudflared 2024+: --origincert es flag global del subcomando `tunnel` (va ANTES de `create`).
    # --output json: devuelve {"id":..., "credentials_file":...} parseable sin ambigüedad,
    # evita el bug previo donde el grep capturaba dos UUIDs (path + "with id") y los concatenaba con \n.
    output=$(cloudflared tunnel --origincert "$user_cert" create --output json "$tunnel_name" 2>&1)
    local create_rc=$?

    # Parseo robusto vía jq; fallback a regex estricta + head -n1 si cloudflared no devolviera JSON
    local uuid
    uuid=$(echo "$output" | jq -r '.id' 2>/dev/null)
    if [ -z "$uuid" ] || [ "$uuid" = "null" ]; then
        # Fallback legacy: primera UUID válida, head -n1 evita concatenar varias, tr limpia \n y espacios
        uuid=$(echo "$output" | grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}' | head -n1 | tr -d '[:space:]')
    fi

    if [ "$create_rc" -ne 0 ] || [ -z "$uuid" ]; then
        log_error "Failed to create tunnel or get UUID."
        echo "$output"
        return 1
    fi

    # Path de credenciales: usar el del JSON si existe, derivar del UUID si no
    local creds_path
    creds_path=$(echo "$output" | jq -r '.credentials_file' 2>/dev/null)
    if [ -z "$creds_path" ] || [ "$creds_path" = "null" ] || [ ! -f "$creds_path" ]; then
        creds_path="$DEFAULT_CLOUDFLARED_DIR/$uuid.json"
    fi

    mkdir -p "$tunnel_dir"
    mv "$creds_path" "$tunnel_dir/creds.json"

    # Save meta — printf %s evita que un valor con \n rompa la línea;
    # CREATED_AT en ISO (sin espacios) para que `source $meta` no interprete "May" como comando
    local id=$(get_next_id)
    {
        printf 'UUID=%s\n' "$uuid"
        printf 'USER=%s\n' "$username"
        printf 'NAME=%s\n' "$tunnel_name"
        printf 'ID=%s\n' "$id"
        printf 'CREATED_AT=%s\n' "$(date -Iseconds)"
    } > "$tunnel_dir/meta"

    # Add to DB
    add_to_db "$id" "$tunnel_name" "$username"

    log_success "Tunnel created with ID $id"
}

cmd_start_tunnel() {
    local input=$1
    local target=$2
    
    if [ -z "$input" ]; then
        log_error "Usage: mcf start <id|name> [url|port]"
        return 1
    fi

    local tunnel_name=$(get_tunnel_by_id_or_name "$input")
    if [ -z "$tunnel_name" ]; then log_error "Tunnel not found"; return 1; fi
    
    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    
    # Handle target
    local url=""
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        url="http://localhost:$target"
    elif [[ "$target" == http* ]]; then
        url="$target"
    elif [ -z "$target" ]; then
        # Try to read last URL from meta
        if [ -f "$tunnel_dir/meta" ]; then
             url=$(grep "^URL=" "$tunnel_dir/meta" | cut -d= -f2)
        fi
    fi
    
    if [ -z "$url" ]; then
        log_error "No URL/Port provided and no history found."
        return 1
    fi

    if [ -f "$tunnel_dir/pid" ]; then
        local pid=$(cat "$tunnel_dir/pid")
        if ps -p "$pid" > /dev/null; then
            log_error "Already running (PID: $pid)"
            return 1
        else
            rm "$tunnel_dir/pid"
        fi
    fi
    
    source "$tunnel_dir/meta"
    
    nohup cloudflared tunnel run --url "$url" --credentials-file "$tunnel_dir/creds.json" "$UUID" > "$LOGS_DIR/$tunnel_name.log" 2>&1 &
    local pid=$!
    echo "$pid" > "$tunnel_dir/pid"
    
    # Update URL in meta
    # Remove old URL line
    grep -v "^URL=" "$tunnel_dir/meta" > "$tunnel_dir/meta.tmp"
    mv "$tunnel_dir/meta.tmp" "$tunnel_dir/meta"
    echo "URL=$url" >> "$tunnel_dir/meta"
    
    log_success "Started tunnel '$tunnel_name' (ID: $ID) -> $url"
}

cmd_stop_tunnel() {
    local input=$1
    local tunnel_name=$(get_tunnel_by_id_or_name "$input")
    [ -z "$tunnel_name" ] && { log_error "Tunnel not found"; return 1; }
    
    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    if [ -f "$tunnel_dir/pid" ]; then
        local pid=$(cat "$tunnel_dir/pid")
        kill "$pid" 2>/dev/null
        rm "$tunnel_dir/pid"
        log_success "Stopped $tunnel_name"
    else
        log_warning "Not running"
    fi
}

cmd_restart_tunnel() {
    local input=$1
    cmd_stop_tunnel "$input"
    sleep 1
    cmd_start_tunnel "$input"
}

cmd_delete_tunnel() {
    local input=$1
    local tunnel_name=$(get_tunnel_by_id_or_name "$input")
    [ -z "$tunnel_name" ] && { log_error "Tunnel not found"; return 1; }
    
    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    
    # Check ID
    local id=$(get_id_by_name "$tunnel_name")
    
    cmd_stop_tunnel "$input" > /dev/null 2>&1
    
    if [ -f "$tunnel_dir/meta" ]; then
         local uuid=$(grep "^UUID=" "$tunnel_dir/meta" | cut -d= -f2)
         # Cleanup cloudflare side? skipping for safety or speed
         # Ideally we should clean up if cert is available
    fi

    rm -rf "$tunnel_dir"
    remove_from_db "$id"
    log_success "Deleted tunnel $tunnel_name"
}

cmd_logs() {
    local input=$1
    shift
    local lines=20
    while [[ "$#" -gt 0 ]]; do
        case $1 in --lines) lines="$2"; shift ;; *) shift ;; esac
    done
    
    local tunnel_name=$(get_tunnel_by_id_or_name "$input")
    [ -z "$tunnel_name" ] && { log_error "Tunnel not found"; return 1; }
    
    local log_file="$LOGS_DIR/$tunnel_name.log"
    if [ -f "$log_file" ]; then
        tail -n "$lines" -f "$log_file"
    else
        log_error "No logs found for $tunnel_name"
    fi
}

cmd_route_tunnel() {
    local input=$1
    local hostname=$2
    local tunnel_name=$(get_tunnel_by_id_or_name "$input")
    [ -z "$tunnel_name" ] && { log_error "Tunnel not found"; return 1; }
    
    local tunnel_dir="$TUNNELS_DIR/$tunnel_name"
    local user=$(grep "^USER=" "$tunnel_dir/meta" | cut -d= -f2)
    local uuid=$(grep "^UUID=" "$tunnel_dir/meta" | cut -d= -f2)
    local user_cert="$USERS_DIR/$user/cert.pem"
    
    [ ! -f "$user_cert" ] && { log_error "User cert missing"; return 1; }
    
    # Swap certs
    if [ -f "$DEFAULT_CLOUDFLARED_DIR/cert.pem" ]; then
        mv "$DEFAULT_CLOUDFLARED_DIR/cert.pem" "$DEFAULT_CLOUDFLARED_DIR/cert.pem.bak"
    fi
    cp "$user_cert" "$DEFAULT_CLOUDFLARED_DIR/cert.pem"
    
    cloudflared tunnel route dns "$uuid" "$hostname"
    local ret=$?
    
    # Restore
    rm "$DEFAULT_CLOUDFLARED_DIR/cert.pem"
    [ -f "$DEFAULT_CLOUDFLARED_DIR/cert.pem.bak" ] && mv "$DEFAULT_CLOUDFLARED_DIR/cert.pem.bak" "$DEFAULT_CLOUDFLARED_DIR/cert.pem"
    
    if [ $ret -eq 0 ]; then
        # Acumular hostnames como lista CSV en una sola línea HOSTNAME=...
        # (antes sobreescribía, así `mcf list` solo mostraba el último route)
        local existing_hostnames
        existing_hostnames=$(grep "^HOSTNAME=" "$tunnel_dir/meta" | cut -d= -f2-)
        local new_hostnames
        if [ -z "$existing_hostnames" ]; then
            new_hostnames="$hostname"
        elif [[ ",$existing_hostnames," == *",$hostname,"* ]]; then
            # Ya está en la lista, no duplicar
            new_hostnames="$existing_hostnames"
        else
            new_hostnames="$existing_hostnames,$hostname"
        fi
        grep -v "^HOSTNAME=" "$tunnel_dir/meta" > "$tunnel_dir/meta.tmp"
        mv "$tunnel_dir/meta.tmp" "$tunnel_dir/meta"
        printf 'HOSTNAME=%s\n' "$new_hostnames" >> "$tunnel_dir/meta"
        log_success "Routed $hostname -> $tunnel_name"
    else
        log_error "Failed to route"
    fi
}

cmd_list_tunnels() {
    printf "${CYAN}%-4s %-15s %-15s %-10s %-8s %-25s %-20s${NC}\n" "ID" "NAME" "USER" "STATUS" "PID" "HOSTNAME" "LOCAL"
    echo "-------------------------------------------------------------------------------------------------------"
    
    if [ -f "$DB_FILE" ]; then
        while IFS='|' read -r id name user; do
            local tunnel_dir="$TUNNELS_DIR/$name"
            if [ -d "$tunnel_dir" ]; then
                local status="${RED}STOPPED${NC}"
                local pid="-"
                local hostname="-"
                local url="-"
                
                if [ -f "$tunnel_dir/meta" ]; then
                    hostname=$(grep "^HOSTNAME=" "$tunnel_dir/meta" | cut -d= -f2)
                    url=$(grep "^URL=" "$tunnel_dir/meta" | cut -d= -f2)
                fi
                [ -z "$hostname" ] && hostname="-"
                [ -z "$url" ] && url="-"

                if [ -f "$tunnel_dir/pid" ]; then
                    local p=$(cat "$tunnel_dir/pid")
                    if ps -p "$p" > /dev/null; then
                        status="${GREEN}ONLINE${NC}"
                        pid=$p
                    else
                        status="${RED}ERR${NC}"
                    fi
                fi
                
                printf "%-4s %-15s %-15s %-19s %-8s %-25s %-20s\n" "$id" "$name" "$user" "$status" "$pid" "$hostname" "$url"
            fi
        done < "$DB_FILE"
    else
        echo "No tunnels found."
    fi
}

cmd_save() {
    # Dump currently running tunnels to a file
    log_info "Saving current process list..."
    > "$DUMP_FILE"
    if [ -f "$DB_FILE" ]; then
        while IFS='|' read -r id name user; do
            local tunnel_dir="$TUNNELS_DIR/$name"
            if [ -f "$tunnel_dir/pid" ] && ps -p $(cat "$tunnel_dir/pid") >/dev/null; then
                # It is running
                echo "$name" >> "$DUMP_FILE"
            fi
        done < "$DB_FILE"
    fi
    log_success "Saved running tunnels to $DUMP_FILE"
}

cmd_resurrect() {
    log_info "Resurrecting tunnels..."
    if [ -f "$DUMP_FILE" ]; then
        while read -r name; do
            log_info "Starting $name..."
            cmd_start_tunnel "$name" ""
        done < "$DUMP_FILE"
    else
        log_error "No save dump found."
    fi
}

cmd_startup() {
    # Create systemd service
    local service_file="/etc/systemd/system/mcf.service"
    local mcf_path=$(realpath "$0")
    
    log_info "Generating systemd service..."
    
    # Need sudo for this
    if [ "$EUID" -ne 0 ]; then 
        log_warning "Root privileges needed to setup startup service. Running sudo..."
        sudo bash -c "cat > $service_file" <<EOF
[Unit]
Description=Multi-Cloudflared Manager
After=network.target

[Service]
Type=forking
User=$USER
ExecStart=$mcf_path resurrect
Environment=HOME=$HOME

[Install]
WantedBy=multi-user.target
EOF
        sudo systemctl daemon-reload
        sudo systemctl enable mcf
        log_success "Startup service enabled."
        echo "You can now use 'mcf save' to freeze the process list."
    else
        cat > "$service_file" <<EOF
[Unit]
Description=Multi-Cloudflared Manager
After=network.target

[Service]
Type=forking
User=$USER
ExecStart=$mcf_path resurrect
Environment=HOME=$HOME

[Install]
WantedBy=multi-user.target
EOF
        systemctl daemon-reload
        systemctl enable mcf
        log_success "Startup service enabled."
    fi
}

# Main Dispatcher
init_dirs

case "$1" in
    setup) check_deps; log_success "Ready." ;;
    create) shift; 
        if [ "$1" == "user" ]; then shift; cmd_create_user "$@"
        elif [ "$1" == "tunnel" ]; then shift; cmd_create_tunnel "$@"
        fi ;;
    add) shift; [ "$1" == "domain" ] && { shift; cmd_add_domain "$@"; } ;;
    route) shift; cmd_route_tunnel "$@" ;;
    list) shift; 
        if [ "$1" == "users" ]; then cmd_list_users
        else cmd_list_tunnels
        fi ;;
    start) shift; cmd_start_tunnel "$@" ;;
    stop) shift; cmd_stop_tunnel "$@" ;;
    restart) shift; cmd_restart_tunnel "$@" ;;
    delete) shift; cmd_delete_tunnel "$@" ;;
    logs) shift; cmd_logs "$@" ;;
    save) cmd_save ;;
    resurrect) cmd_resurrect ;;
    startup) cmd_startup ;;
    help|--help|-h|*) 
        show_banner
        echo "Commands:"
        echo "  create user <name>         Add account"
        echo "  create tunnel <name> ...   Add tunnel"
        echo "  list                       Show status table"
        echo "  start <id|name> [port]     Start tunnel"
        echo "  stop <id|name>             Stop tunnel"
        echo "  restart <id|name>          Restart tunnel"
        echo "  logs <id|name>             Tail logs"
        echo "  route <id|name> <host>     Route DNS"
        echo "  save                       Save running list"
        echo "  startup                    Enable boot start"
        ;;
esac
